<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Chatbot</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #212121;
      --sidebar:   #171717;
      --surface:   #2f2f2f;
      --border:    #3f3f3f;
      --text:      #ececec;
      --muted:     #8e8ea0;
      --accent:    #10a37f;
      --accent-h:  #0d8a6c;
      --user-bg:   #2f2f2f;
      --ai-bg:     transparent;
      --danger:    #ef4444;
      --radius:    12px;
      --font:      'Segoe UI', system-ui, sans-serif;
    }

    body {
      font-family: var(--font);
      font-size: 13px;
      background: var(--bg);
      color: var(--text);
      height: 100vh;
      display: flex;
      overflow: hidden;
    }

    /* ── AUTH OVERLAY ──────────────────────────── */
    #authOverlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.7);
      backdrop-filter: blur(6px);
      display: flex; align-items: center; justify-content: center;
      z-index: 100;
    }
    #authOverlay.hidden { display: none; }
    .auth-box {
      background: #1e1e1e;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px 28px;
      width: 380px;
      display: flex; flex-direction: column; gap: 16px;
    }
    .auth-box h2 { font-size: 18px; font-weight: 600; }
    .auth-box p  { color: var(--muted); font-size: 12px; line-height: 1.5; }

    /* ── SIDEBAR ───────────────────────────────── */
    #sidebar {
      width: 240px;
      background: var(--sidebar);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column;
      flex-shrink: 0;
    }

    .sidebar-top {
      padding: 12px 10px 8px;
      border-bottom: 1px solid var(--border);
    }

    #newChatBtn {
      width: 100%;
      display: flex; align-items: center; gap: 8px;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      padding: 8px 12px;
      font-size: 13px;
      cursor: pointer;
      transition: background .15s;
    }
    #newChatBtn:hover { background: var(--surface); }
    #newChatBtn svg { flex-shrink: 0; }

    .sidebar-label {
      padding: 10px 12px 4px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .06em;
      color: var(--muted);
      text-transform: uppercase;
    }

    #sessionList {
      flex: 1;
      overflow-y: auto;
      padding: 0 6px 8px;
    }
    #sessionList::-webkit-scrollbar { width: 4px; }
    #sessionList::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    .sess-item {
      display: flex; align-items: center; gap: 6px;
      padding: 7px 8px;
      border-radius: 8px;
      cursor: pointer;
      color: var(--text);
      font-size: 12px;
      transition: background .12s;
      position: relative;
    }
    .sess-item:hover { background: var(--surface); }
    .sess-item.active { background: #3a3a3a; }
    .sess-title { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sess-del {
      display: none; border: none; background: none;
      color: var(--muted); cursor: pointer; padding: 2px 4px; border-radius: 4px; font-size: 14px; line-height: 1;
    }
    .sess-item:hover .sess-del { display: block; }
    .sess-del:hover { color: var(--danger); }

    /* upload section in sidebar */
    .sidebar-upload {
      padding: 10px;
      border-top: 1px solid var(--border);
    }
    .upload-label {
      font-size: 10px; font-weight: 700; letter-spacing: .06em;
      color: var(--muted); text-transform: uppercase; margin-bottom: 6px; display: block;
    }
    .file-drop {
      border: 1px dashed var(--border);
      border-radius: 8px;
      padding: 10px;
      text-align: center;
      cursor: pointer;
      color: var(--muted);
      font-size: 11px;
      transition: border-color .15s, background .15s;
    }
    .file-drop:hover, .file-drop.dragover { border-color: var(--accent); background: rgba(16,163,127,.07); color: var(--text); }
    .file-drop input[type=file] { display: none; }
    #uploadStatus {
      margin-top: 6px; font-size: 11px; color: var(--muted);
      min-height: 14px;
    }
    #uploadStatus.ok  { color: var(--accent); }
    #uploadStatus.err { color: var(--danger); }

    /* ── MAIN ──────────────────────────────────── */
    #main {
      flex: 1; display: flex; flex-direction: column; overflow: hidden;
    }

    /* top bar */
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 16px;
      border-bottom: 1px solid var(--border);
      background: var(--bg);
      flex-shrink: 0;
    }
    .topbar-title { font-weight: 600; font-size: 14px; }
    #statusDot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--muted); display: inline-block; margin-right: 6px;
    }
    #statusDot.on { background: var(--accent); }
    #statusDot.err { background: var(--danger); }

    /* chat area */
    #chatArea {
      flex: 1; overflow-y: auto; padding: 20px 0;
      display: flex; flex-direction: column;
    }
    #chatArea::-webkit-scrollbar { width: 5px; }
    #chatArea::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    .empty-state {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      color: var(--muted); gap: 10px;
    }
    .empty-state svg { opacity: .3; }
    .empty-state p { font-size: 14px; }

    /* bubbles */
    .msg-row {
      display: flex; padding: 4px 0; animation: fadeIn .2s ease;
    }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

    .msg-row.user { justify-content: flex-end; }
    .msg-row.ai   { justify-content: flex-start; }

    .bubble {
      max-width: 70%;
      padding: 10px 14px;
      border-radius: var(--radius);
      line-height: 1.6;
      font-size: 13px;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .msg-row.user .bubble {
      background: var(--user-bg);
      border-bottom-right-radius: 3px;
      color: var(--text);
    }
    .msg-row.ai .bubble {
      background: var(--ai-bg);
      border-bottom-left-radius: 3px;
      color: var(--text);
      padding-left: 0;
    }

    .msg-wrap { display: flex; align-items: flex-start; gap: 10px; max-width: 780px; width: 100%; margin: 0 auto; padding: 0 20px; }
    .msg-row.user .msg-wrap { flex-direction: row-reverse; }

    .avatar {
      width: 28px; height: 28px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; flex-shrink: 0; margin-top: 2px;
    }
    .avatar.user { background: #6366f1; color: white; }
    .avatar.ai   { background: var(--accent); color: white; }

    /* streaming cursor */
    .cursor {
      display: inline-block; width: 2px; height: 14px;
      background: var(--accent); margin-left: 2px;
      animation: blink .7s step-end infinite; vertical-align: middle;
    }
    @keyframes blink { 50% { opacity: 0; } }

    /* composer */
    .composer-wrap {
      padding: 12px 20px 16px;
      background: var(--bg);
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }
    .composer-inner {
      max-width: 780px; margin: 0 auto;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      display: flex; align-items: flex-end; gap: 8px;
      padding: 8px 10px;
      transition: border-color .15s;
    }
    .composer-inner:focus-within { border-color: #666; }

    #msgInput {
      flex: 1; background: none; border: none; outline: none;
      color: var(--text); font: inherit; font-size: 13px;
      resize: none; min-height: 24px; max-height: 160px;
      line-height: 1.5; padding: 2px 0;
    }
    #msgInput::placeholder { color: var(--muted); }

    #sendBtn {
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--accent); border: none;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; flex-shrink: 0;
      transition: background .15s, opacity .15s;
    }
    #sendBtn:hover  { background: var(--accent-h); }
    #sendBtn:disabled { opacity: .35; cursor: default; }

    /* ── SHARED INPUT STYLES ───────────────────── */
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: 11px; font-weight: 600; color: var(--muted); }
    .inp {
      background: #2a2a2a; border: 1px solid var(--border);
      border-radius: 8px; padding: 8px 11px;
      color: var(--text); font: inherit; font-size: 13px; outline: none;
      width: 100%;
    }
    .inp:focus { border-color: #666; }

    .btn {
      padding: 8px 16px; border-radius: 8px; border: none;
      font: inherit; font-size: 13px; font-weight: 600;
      cursor: pointer; transition: background .15s, opacity .15s;
    }
    .btn-primary { background: var(--accent); color: white; }
    .btn-primary:hover { background: var(--accent-h); }
    .btn:disabled { opacity: .4; cursor: default; }
  </style>
</head>
<body>

<!-- ── AUTH OVERLAY ──────────────────────── -->
<div id="authOverlay">
  <div class="auth-box">
    <h2>🤖 AI Chatbot</h2>
    <p>Paste your JWT token to connect. You can get it from <code>/api/auth/login</code>.</p>
    <div class="field">
      <label>JWT Token</label>
      <input id="tokenInput" class="inp" type="password" placeholder="eyJhbGci…" autocomplete="off" />
    </div>
    <button id="connectBtn" class="btn btn-primary">Connect</button>
    <div id="authError" style="color:var(--danger);font-size:12px;min-height:16px;"></div>
  </div>
</div>

<!-- ── SIDEBAR ───────────────────────────── -->
<div id="sidebar">
  <div class="sidebar-top">
    <button id="newChatBtn">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
      New Chat
    </button>
  </div>
  <div class="sidebar-label">Sessions</div>
  <div id="sessionList"></div>

  <!-- file upload -->
  <div class="sidebar-upload">
    <span class="upload-label">📎 Upload Document</span>
    <div class="file-drop" id="fileDrop">
      <input type="file" id="fileInput" accept=".pdf,.txt,.docx" />
      Drop file or <u>browse</u><br/>PDF · TXT · DOCX
    </div>
    <div id="uploadStatus"></div>
  </div>
</div>

<!-- ── MAIN ──────────────────────────────── -->
<div id="main">
  <div class="topbar">
    <div class="topbar-title">
      <span id="statusDot"></span>
      <span id="sessionTitle">Select a session</span>
    </div>
    <div style="color:var(--muted);font-size:11px;" id="connectedAs"></div>
  </div>

  <div id="chatArea">
    <div class="empty-state" id="emptyState">
      <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <p>Create or select a session to start chatting</p>
    </div>
  </div>

  <div class="composer-wrap">
    <div class="composer-inner">
      <textarea id="msgInput" rows="1" placeholder="Message…" disabled></textarea>
      <button id="sendBtn" disabled>
        <svg width="16" height="16" fill="none" stroke="white" stroke-width="2.2" viewBox="0 0 24 24"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      </button>
    </div>
  </div>
</div>

<script src="https://cdn.socket.io/4.8.1/socket.io.min.js"></script>
<script>
  const SERVER = '<%= defaultServerUrl %>';

  // ── State ────────────────────────────────────────
  let token = '';
  let socket = null;
  let currentSessionId = null;
  let streamRow = null;
  let streamText = '';
  let isStreaming = false;

  // ── DOM refs ─────────────────────────────────────
  const authOverlay  = document.getElementById('authOverlay');
  const authError    = document.getElementById('authError');
  const tokenInput   = document.getElementById('tokenInput');
  const connectBtn   = document.getElementById('connectBtn');
  const statusDot    = document.getElementById('statusDot');
  const sessionTitle = document.getElementById('sessionTitle');
  const connectedAs  = document.getElementById('connectedAs');
  const sessionList  = document.getElementById('sessionList');
  const newChatBtn   = document.getElementById('newChatBtn');
  const chatArea     = document.getElementById('chatArea');
  const emptyState   = document.getElementById('emptyState');
  const msgInput     = document.getElementById('msgInput');
  const sendBtn      = document.getElementById('sendBtn');
  const fileDrop     = document.getElementById('fileDrop');
  const fileInput    = document.getElementById('fileInput');
  const uploadStatus = document.getElementById('uploadStatus');

  // ── Auth / Connect ───────────────────────────────
  connectBtn.addEventListener('click', doConnect);
  tokenInput.addEventListener('keydown', e => { if (e.key === 'Enter') doConnect(); });

  function doConnect() {
    const t = tokenInput.value.trim();
    if (!t) { authError.textContent = 'Token is required.'; return; }
    token = t;
    authError.textContent = '';
    connectBtn.disabled = true;
    connectBtn.textContent = 'Connecting…';
    initSocket();
  }

  function initSocket() {
    if (socket) socket.disconnect();
    socket = io(SERVER, {
      auth: { token, authorization: `Bearer ${token}` },
      transportOptions: { polling: { extraHeaders: { Authorization: `Bearer ${token}` } } }
    });

    socket.on('connect', () => {
      authOverlay.classList.add('hidden');
      statusDot.className = 'on';
      connectedAs.textContent = `socket: ${socket.id.slice(0,8)}…`;
      loadSessions();
    });

    socket.on('connect_error', err => {
      authError.textContent = err.message || 'Connection failed. Check your token.';
      connectBtn.disabled = false;
      connectBtn.textContent = 'Connect';
      statusDot.className = 'err';
    });

    socket.on('disconnect', () => {
      statusDot.className = '';
      connectedAs.textContent = 'Disconnected';
    });

    socket.on('chat_token', ({ content }) => {
      if (!streamRow) {
        streamRow = appendBubble('ai', '');
        isStreaming = true;
      }
      streamText += content;
      const bubble = streamRow.querySelector('.bubble');
      // remove old cursor
      const oldCursor = bubble.querySelector('.cursor');
      if (oldCursor) oldCursor.remove();
      bubble.appendChild(document.createTextNode(content));
      // add cursor
      const cur = document.createElement('span');
      cur.className = 'cursor';
      bubble.appendChild(cur);
      scrollBottom();
    });

    socket.on('chat_done', () => {
      if (streamRow) {
        const bubble = streamRow.querySelector('.bubble');
        const cur = bubble.querySelector('.cursor');
        if (cur) cur.remove();
      }
      streamRow = null;
      streamText = '';
      isStreaming = false;
      setInputEnabled(true);
    });

    socket.on('error', payload => {
      const msg = typeof payload === 'object' ? JSON.stringify(payload) : String(payload);
      appendBubble('ai', `⚠️ ${msg}`);
      setInputEnabled(true);
    });
  }

  // ── Sessions ──────────────────────────────────────
  async function loadSessions() {
    try {
      const res = await apiFetch('/api/chat/sessions');
      const sessions = await res.json();
      renderSessions(sessions);
    } catch { /* ignore */ }
  }

  function renderSessions(sessions) {
    sessionList.innerHTML = '';
    if (!sessions.length) {
      sessionList.innerHTML = '<div style="padding:10px 12px;color:var(--muted);font-size:11px;">No sessions yet</div>';
      return;
    }
    sessions.forEach(s => {
      const item = document.createElement('div');
      item.className = 'sess-item' + (s._id === currentSessionId ? ' active' : '');
      item.dataset.id = s._id;
      item.innerHTML = `
        <span class="sess-title">${escHtml(s.title || 'Untitled')}</span>
        <button class="sess-del" title="Delete" data-id="${s._id}">✕</button>
      `;
      item.addEventListener('click', e => {
        if (e.target.classList.contains('sess-del')) return;
        selectSession(s._id, s.title || 'Untitled');
      });
      item.querySelector('.sess-del').addEventListener('click', async e => {
        e.stopPropagation();
        await deleteSession(s._id);
      });
      sessionList.appendChild(item);
    });
  }

  newChatBtn.addEventListener('click', async () => {
    const title = `Chat ${new Date().toLocaleTimeString('en', { hour: '2-digit', minute: '2-digit' })}`;
    try {
      const res = await apiFetch('/api/chat/sessions', { method: 'POST', body: JSON.stringify({ title }) });
      const session = await res.json();
      await loadSessions();
      selectSession(session._id, session.title || 'Untitled');
    } catch { /* ignore */ }
  });

  async function selectSession(id, title) {
    currentSessionId = id;
    sessionTitle.textContent = title;
    setInputEnabled(true);
    // highlight
    document.querySelectorAll('.sess-item').forEach(el => el.classList.toggle('active', el.dataset.id === id));
    // load history
    chatArea.innerHTML = '';
    try {
      const res = await apiFetch(`/api/chat/${id}`);
      const chats = await res.json();
      if (!chats.length) {
        chatArea.appendChild(emptyState);
        return;
      }
      chats.forEach(c => appendBubble(c.role === 'user' ? 'user' : 'ai', c.message));
      scrollBottom();
    } catch {
      chatArea.appendChild(emptyState);
    }
  }

  async function deleteSession(id) {
    try {
      await apiFetch(`/api/chat/sessions/${id}`, { method: 'DELETE' });
      if (currentSessionId === id) {
        currentSessionId = null;
        sessionTitle.textContent = 'Select a session';
        chatArea.innerHTML = '';
        chatArea.appendChild(emptyState);
        setInputEnabled(false);
      }
      await loadSessions();
    } catch { /* ignore */ }
  }

  // ── Send message ──────────────────────────────────
  sendBtn.addEventListener('click', sendMessage);
  msgInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
  msgInput.addEventListener('input', () => {
    msgInput.style.height = 'auto';
    msgInput.style.height = Math.min(msgInput.scrollHeight, 160) + 'px';
  });

  function sendMessage() {
    const message = msgInput.value.trim();
    if (!socket || !message || !currentSessionId || isStreaming) return;
    appendBubble('user', message);
    socket.emit('send_message', { sessionId: currentSessionId, message });
    msgInput.value = '';
    msgInput.style.height = 'auto';
    setInputEnabled(false);
    scrollBottom();
  }

  // ── File Upload ───────────────────────────────────
  fileDrop.addEventListener('click', () => fileInput.click());
  fileDrop.addEventListener('dragover', e => { e.preventDefault(); fileDrop.classList.add('dragover'); });
  fileDrop.addEventListener('dragleave', () => fileDrop.classList.remove('dragover'));
  fileDrop.addEventListener('drop', e => {
    e.preventDefault(); fileDrop.classList.remove('dragover');
    const file = e.dataTransfer.files[0];
    if (file) uploadFile(file);
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) uploadFile(fileInput.files[0]);
  });

  async function uploadFile(file) {
    const allowed = ['application/pdf', 'text/plain',
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
    if (!allowed.includes(file.type)) {
      setUploadStatus('❌ Only PDF, TXT, DOCX allowed', 'err'); return;
    }
    setUploadStatus('⏳ Uploading…', '');
    const form = new FormData();
    form.append('file', file);
    try {
      const res = await fetch(`${SERVER}/api/docs/upload`, {
        method: 'POST',
        headers: { Authorization: `Bearer ${token}` },
        body: form
      });
      const data = await res.json();
      if (data.success) setUploadStatus(`✅ ${data.filename}`, 'ok');
      else setUploadStatus(`❌ ${data.message}`, 'err');
    } catch (err) {
      setUploadStatus('❌ Upload failed', 'err');
    }
    fileInput.value = '';
  }

  function setUploadStatus(msg, cls) {
    uploadStatus.textContent = msg;
    uploadStatus.className = cls;
  }

  // ── UI helpers ────────────────────────────────────
  function appendBubble(role, text) {
    const isUser = role === 'user';

    // remove empty state if present
    if (emptyState.parentElement === chatArea) chatArea.removeChild(emptyState);

    const row = document.createElement('div');
    row.className = `msg-row ${isUser ? 'user' : 'ai'}`;

    const wrap = document.createElement('div');
    wrap.className = 'msg-wrap';

    const avatar = document.createElement('div');
    avatar.className = `avatar ${isUser ? 'user' : 'ai'}`;
    avatar.textContent = isUser ? 'U' : 'AI';

    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.textContent = text;

    wrap.appendChild(avatar);
    wrap.appendChild(bubble);
    row.appendChild(wrap);
    chatArea.appendChild(row);
    return row;
  }

  function setInputEnabled(enabled) {
    msgInput.disabled = !enabled || !currentSessionId;
    sendBtn.disabled  = !enabled || !currentSessionId;
    if (enabled && currentSessionId) msgInput.focus();
  }

  function scrollBottom() {
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  function apiFetch(path, opts = {}) {
    return fetch(`${SERVER}${path}`, {
      ...opts,
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${token}`,
        ...(opts.headers || {})
      }
    });
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
</script>
</body>
</html>